{"t": "2026-04-27T00:28:59.027347+00:00", "iter": 49, "type": "tool", "name": "write_file", "args": {"content": "\"\"\"Tests for utility functions.\"\"\"\nfrom __future__ import annotations\n\nfrom datetime import datetime, timezone\n\nfrom logalyzer.utils import format_bytes, parse_iso_date\n\n\ndef test_parse_iso_date_midnight_utc():\n    result = parse_iso_date(\"2026-01-15\")\n    assert result == datetime(2026, 1, 15, 0, 0, 0, tzinfo=timezone.utc)\n\n\ndef test_parse_iso_date_different_dates():\n    result = parse_iso_date(\"2025-12-31\")\n    assert result == datetime(2025, 12, 31, 0, 0, 0, tzinfo=timezone.utc)\n\n\ndef test_format_bytes_small():\n    assert format_bytes(0) == \"0.0 B\"\n    assert format_bytes(500) == \"500.0 B\"\n\n\ndef test_format_bytes_kb():\n    assert format_bytes(1024) == \"1.0 KB\"\n    assert format_bytes(2048) == \"2.0 KB\"\n\n\ndef test_format_bytes_mb():\n    assert format_bytes(1048576) == \"1.0 MB\"\n\n\ndef test_format_bytes_gb():\n    assert format_bytes(1073741824) == \"1.0 GB\"\n\n\ndef test_format_bytes_large():\n    result = format_bytes(1099511627776)\n    assert \"TB\" in result\n", "path": "/workspace/tests/test_utils.py"}, "wall_s": 0.07, "result_len": 49}
