{"t": "2026-04-27T00:28:04.668241+00:00", "iter": 46, "type": "tool", "name": "write_file", "args": {"content": "\"\"\"Tests for I/O helpers.\"\"\"\nfrom __future__ import annotations\n\nimport tempfile\nfrom pathlib import Path\n\nfrom logalyzer.io import load, load_iter\nfrom logalyzer.parser import LogEntry\n\nSAMPLE_LINE = '10.0.0.1 - - [15/Jan/2026:08:30:00 +0000] \"GET /index.html HTTP/1.1\" 200 1234\\n'\nSAMPLE_LINE2 = '10.0.0.2 - alice [15/Jan/2026:08:30:15 +0000] \"POST /api/login HTTP/1.1\" 200 56\\n'\n\n\ndef test_load_returns_list_of_entries():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(SAMPLE_LINE)\n        f.write(SAMPLE_LINE2)\n        path = f.name\n\n    entries = load(path)\n    assert isinstance(entries, list)\n    assert len(entries) == 2\n    assert entries[0].ip == \"10.0.0.1\"\n    assert entries[1].ip == \"10.0.0.2\"\n\n    Path(path).unlink()\n\n\ndef test_load_skips_garbage_lines():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(SAMPLE_LINE)\n        f.write(\"this is garbage\\n\")\n        f.write(SAMPLE_LINE2)\n        path = f.name\n\n    entries = load(path)\n    assert len(entries) == 2\n\n    Path(path).unlink()\n\n\ndef test_load_empty_file():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        path = f.name\n\n    entries = load(path)\n    assert entries == []\n\n    Path(path).unlink()\n\n\ndef test_load_iter_yields_entries():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(SAMPLE_LINE)\n        f.write(SAMPLE_LINE2)\n        path = f.name\n\n    entries = list(load_iter(path))\n    assert len(entries) == 2\n    assert entries[0].ip == \"10.0.0.1\"\n\n    Path(path).unlink()\n\n\ndef test_load_iter_is_a_generator():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(SAMPLE_LINE)\n        path = f.name\n\n    result = load_iter(path)\n    # Should be a generator, not a list\n    import types\n    assert isinstance(result, types.GeneratorType)\n\n    Path(path).unlink()\n\n\ndef test_load_handles_file_without_trailing_newline():\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(SAMPLE_LINE.rstrip('\\n'))  # no trailing newline\n        path = f.name\n\n    entries = load(path)\n    assert len(entries) == 1\n    assert entries[0].ip == \"10.0.0.1\"\n\n    Path(path).unlink()\n", "path": "/workspace/tests/test_io.py"}, "wall_s": 0.07, "result_len": 47}
