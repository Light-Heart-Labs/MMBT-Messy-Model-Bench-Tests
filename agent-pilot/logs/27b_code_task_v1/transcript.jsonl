{"t": "2026-04-27T00:29:19.150775+00:00", "iter": 50, "type": "tool", "name": "write_file", "args": {"content": "\"\"\"Tests for CLI entry point.\"\"\"\nfrom __future__ import annotations\n\nfrom datetime import datetime, timezone\n\nfrom logalyzer.cli import build_parser, main\nfrom logalyzer.parser import LogEntry\n\n\ndef test_build_parser_has_required_args():\n    parser = build_parser()\n    # Should have paths as positional arg\n    assert parser._option_string_actions.get(\"--status\") is not None\n    assert parser._option_string_actions.get(\"--url\") is not None\n    assert parser._option_string_actions.get(\"--ip\") is not None\n    assert parser._option_string_actions.get(\"--since\") is not None\n    assert parser._option_string_actions.get(\"--until\") is not None\n    assert parser._option_string_actions.get(\"--expr\") is not None\n    assert parser._option_string_actions.get(\"--aggregate\") is not None\n    assert parser._option_string_actions.get(\"--top\") is not None\n    assert parser._option_string_actions.get(\"--format\") is not None\n\n\ndef test_build_parser_default_format_is_text():\n    parser = build_parser()\n    args = parser.parse_args([\"/dev/null\"])\n    assert args.format == \"text\"\n\n\ndef test_main_returns_zero_on_success():\n    \"\"\"Running main with a valid log file should return 0.\"\"\"\n    import tempfile\n    line = '10.0.0.1 - - [15/Jan/2026:08:30:00 +0000] \"GET / HTTP/1.1\" 200 100\\n'\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(line)\n        path = f.name\n\n    result = main([path])\n    assert result == 0\n\n    import os\n    os.unlink(path)\n\n\ndef test_main_status_filter():\n    import tempfile\n    lines = (\n        '10.0.0.1 - - [15/Jan/2026:08:30:00 +0000] \"GET / HTTP/1.1\" 200 100\\n'\n        '10.0.0.2 - - [15/Jan/2026:08:30:01 +0000] \"GET / HTTP/1.1\" 404 100\\n'\n    )\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(lines)\n        path = f.name\n\n    result = main([\"--status\", \"404\", path])\n    assert result == 0\n\n    import os\n    os.unlink(path)\n\n\ndef test_main_aggregate_status():\n    import tempfile\n    lines = (\n        '10.0.0.1 - - [15/Jan/2026:08:30:00 +0000] \"GET / HTTP/1.1\" 200 100\\n'\n        '10.0.0.2 - - [15/Jan/2026:08:30:01 +0000] \"GET / HTTP/1.1\" 200 100\\n'\n        '10.0.0.3 - - [15/Jan/2026:08:30:02 +0000] \"GET / HTTP/1.1\" 404 100\\n'\n    )\n    with tempfile.NamedTemporaryFile(mode=\"w\", suffix=\".log\", delete=False) as f:\n        f.write(lines)\n        path = f.name\n\n    result = main([\"--aggregate\", \"status\", path])\n    assert result == 0\n\n    import os\n    os.unlink(path)\n", "path": "/workspace/tests/test_cli.py"}, "wall_s": 0.08, "result_len": 48}
