{"t": "2026-04-27T00:27:31.940628+00:00", "iter": 51, "type": "tool", "name": "write_file", "args": {"path": "/workspace/tests/test_utils.py", "content": "\"\"\"Tests for utility functions.\"\"\"\nfrom logalyzer.utils import parse_iso_date, format_bytes, chunked\n\n\ndef test_parse_iso_date():\n    dt = parse_iso_date(\"2026-01-15\")\n    assert dt.year == 2026\n    assert dt.month == 1\n    assert dt.day == 15\n    assert dt.hour == 0\n    assert dt.minute == 0\n    assert dt.second == 0\n\n\ndef test_parse_iso_date_has_utc_timezone():\n    dt = parse_iso_date(\"2026-06-30\")\n    assert dt.tzinfo is not None\n\n\ndef test_format_bytes_small():\n    assert format_bytes(100) == \"100.0 B\"\n    assert format_bytes(1023) == \"1023.0 B\"\n\n\ndef test_format_bytes_kb():\n    assert format_bytes(1024) == \"1.0 KB\"\n    assert format_bytes(2048) == \"2.0 KB\"\n\n\ndef test_format_bytes_mb():\n    assert format_bytes(1024 * 1024) == \"1.0 MB\"\n    assert format_bytes(1024 * 1024 * 5) == \"5.0 MB\"\n\n\ndef test_format_bytes_gb():\n    assert format_bytes(1024 * 1024 * 1024) == \"1.0 GB\"\n\n\ndef test_format_bytes_large():\n    result = format_bytes(1024 * 1024 * 1024 * 1024)\n    assert \"TB\" in result\n\n\ndef test_chunked_empty():\n    assert list(chunked([], 3)) == []\n\n\ndef test_chunked_exact():\n    assert list(chunked([1, 2, 3, 4, 5, 6], 3)) == [[1, 2, 3], [4, 5, 6]]\n\n\ndef test_chunked_partial():\n    assert list(chunked([1, 2, 3, 4, 5], 3)) == [[1, 2, 3], [4, 5]]\n\n\ndef test_chunked_single():\n    assert list(chunked([1], 3)) == [[1]]\n\n\ndef test_chunked_size_one():\n    assert list(chunked([1, 2, 3], 1)) == [[1], [2], [3]]\n"}, "wall_s": 0.07, "result_len": 50}
