{"t": "2026-04-27T00:27:40.787087+00:00", "iter": 53, "type": "tool", "name": "write_file", "args": {"path": "/workspace/tests/test_output.py", "content": "\"\"\"Tests for output formatters.\"\"\"\nfrom datetime import datetime, timezone\n\nfrom logalyzer.output import to_json, to_csv, to_text, render_aggregate\nfrom logalyzer.parser import LogEntry\n\n\ndef make_entry(**kw):\n    defaults = dict(\n        ip=\"10.0.0.1\",\n        user=\"-\",\n        timestamp=datetime(2026, 1, 1, 12, 0, 0, tzinfo=timezone.utc),\n        method=\"GET\",\n        url=\"/\",\n        protocol=\"HTTP/1.1\",\n        status=200,\n        bytes=100,\n    )\n    defaults.update(kw)\n    return LogEntry(**defaults)\n\n\ndef test_to_json_renders_valid_json():\n    entries = [make_entry(ip=\"10.0.0.1\", status=200)]\n    result = to_json(entries)\n    import json\n    parsed = json.loads(result)\n    assert len(parsed) == 1\n    assert parsed[0][\"ip\"] == \"10.0.0.1\"\n    assert parsed[0][\"status\"] == 200\n\n\ndef test_to_json_handles_special_characters():\n    \"\"\"JSON output should properly escape special characters.\"\"\"\n    entries = [make_entry(url='/search?q=\"test\"&foo=bar')]\n    result = to_json(entries)\n    import json\n    parsed = json.loads(result)\n    assert parsed[0][\"url\"] == '/search?q=\"test\"&foo=bar'\n\n\ndef test_to_csv_renders_valid_csv():\n    entries = [make_entry(ip=\"10.0.0.1\", status=200)]\n    result = to_csv(entries)\n    # Handle both \\n and \\r\\n line endings\n    lines = result.replace('\\r\\n', '\\n').replace('\\r', '\\n').strip().split('\\n')\n    assert lines[0] == \"ip,user,timestamp,method,url,protocol,status,bytes\"\n    assert len(lines) == 2\n\n\ndef test_to_text_renders_readable_format():\n    entries = [make_entry(ip=\"10.0.0.1\", status=200, url=\"/test\")]\n    result = to_text(entries)\n    assert \"2026-01-01T12:00:00+00:00\" in result\n    assert \"10.0.0.1\" in result\n    assert \"GET\" in result\n    assert \"200\" in result\n    assert \"/test\" in result\n\n\ndef test_render_aggregate_dict_text():\n    agg = {\"a\": 1, \"b\": 2}\n    result = render_aggregate(agg, fmt=\"text\")\n    assert \"a\\t1\" in result\n    assert \"b\\t2\" in result\n\n\ndef test_render_aggregate_list_text():\n    agg = [(\"a\", 1), (\"b\", 2)]\n    result = render_aggregate(agg, fmt=\"text\")\n    assert \"a\\t1\" in result\n    assert \"b\\t2\" in result\n\n\ndef test_render_aggregate_dict_json():\n    agg = {\"a\": 1, \"b\": 2}\n    result = render_aggregate(agg, fmt=\"json\")\n    import json\n    parsed = json.loads(result)\n    assert parsed == {\"a\": 1, \"b\": 2}\n\n\ndef test_render_aggregate_list_json():\n    agg = [(\"a\", 1), (\"b\", 2)]\n    result = render_aggregate(agg, fmt=\"json\")\n    import json\n    parsed = json.loads(result)\n    assert parsed == {\"a\": 1, \"b\": 2}\n\n\ndef test_render_aggregate_unknown_format_raises():\n    agg = {\"a\": 1}\n    try:\n        render_aggregate(agg, fmt=\"unknown\")\n        assert False, \"Should have raised ValueError\"\n    except ValueError as e:\n        assert \"unknown format\" in str(e)\n"}, "wall_s": 0.08, "result_len": 51}
