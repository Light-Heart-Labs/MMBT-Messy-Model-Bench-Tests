\" in output\n        assert \"/api/login\" in output\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_json_format(capsys):\n    \"\"\"main() should output JSON when requested.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--format\", \"json\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should be valid JSON\n        import json\n        parsed = json.loads(output)\n        assert isinstance(parsed, list)\n        assert len(parsed) > 0\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_csv_format(capsys):\n    \"\"\"main() should output CSV when requested.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--format\", \"csv\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should have CSV header\n        assert \"ip,user,timestamp\" in output\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_ip_filter(capsys):\n    \"\"\"main() should filter by IP.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--ip\", \"10.0.0.1\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should only show entries from 10.0.0.1\n        assert \"10.0.0.1\" in output\n        # Other IPs should not appear\n        assert \"10.0.0.2\" not in output\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_url_regex(capsys):\n    \"\"\"main() should filter by URL regex.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--url\", \"/api/\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should only show API URLs\n        assert \"/api/\" in output\n        assert \"/index.html\" not in output\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_expression_filter(capsys):\n    \"\"\"main() should filter by expression.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--expr\", \"entry.status >= 500\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should only show 500 errors\n        assert \"500\" in output\n        assert \"200\" not in output\n    finally:\n        sys.stdout = old_stdout\n\n\ndef test_main_with_top_limit(capsys):\n    \"\"\"main() should limit aggregate results with --top.\"\"\"\n    old_stdout = sys.stdout\n    sys.stdout = StringIO()\n    \n    try:\n        result = main([str(SAMPLE_LOG), \"--aggregate\", \"url\", \"--top\", \"3\"])\n        output = sys.stdout.getvalue()\n        sys.stdout = old_stdout\n        \n        assert result == 0\n        # Should have at most 3 results\n        lines = [l for l in output.strip().split('\\n') if l]\n        assert len(lines) <= 3\n    finally:\n        sys.stdout = old_stdout\n"}, "wall_s": 0.08, "result_len": 48}
