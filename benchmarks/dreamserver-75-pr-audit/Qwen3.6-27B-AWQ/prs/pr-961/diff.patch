+    } catch (error) {
+      assistantBodyEl.classList.remove("is-streaming");
+      if (error?.name === "AbortError" || state.stopRequestedByUser) {
+        assistantBodyEl.textContent = assistantBodyEl.textContent || ui.stopped;
+        statusTextEl.textContent = ui.stopped;
+      } else {
