+      name: file.name,
+      type: file.type || (file.name.toLowerCase().endsWith(".pdf") ? "application/pdf" : "application/octet-stream"),
+      dataBase64,
+    });
+  }
+
+  attachmentInputEl.value = "";
+  renderAttachments();
+});
