+
+@test "_detect_topo_rocmsmi: parses 2-GPU PCIe topology from rocm-smi" {
+    rocm-smi() {
+        if [[ "$1" == "--showtopo" ]]; then
+            cat "$FIXTURES_DIR/rocm_smi_showtopo_2gpu_pcie.txt"
+        fi
+    }
+
+    run _detect_topo_rocmsmi 2
+    assert_success
+
+    local link_count
+    link_count=$(echo "$output" | jq '. | length')
