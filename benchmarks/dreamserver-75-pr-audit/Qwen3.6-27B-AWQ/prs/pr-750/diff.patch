+
+@test "_detect_topo_amdsmi: single GPU produces no links" {
+    amd-smi() {
+        if [[ "$1" == "topology" && "$2" == "--json" ]]; then
+            echo '[{"gpu":0,"links":[{"gpu":0,"weight":0,"link_type":"SELF"}]}]'
