+            sysfs.update({
+                f"{base}/mem_info_vram_total": str(vram_gb * 1024**3),
+                f"{base}/mem_info_vram_used": str(4 * 1024**3),
+                f"{base}/mem_info_gtt_total": str(8 * 1024**3),
