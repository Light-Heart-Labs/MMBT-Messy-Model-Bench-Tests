+# Print a separator of repeated characters filling the given width.
+# Usage: hr <width> [<char=─>]
+hr() {
+    local w="${1:-10}" c="${2:-─}" out=''
+    printf -v out '%*s' "$w" ''
+    printf '%s' "${out// /$c}"
+}
