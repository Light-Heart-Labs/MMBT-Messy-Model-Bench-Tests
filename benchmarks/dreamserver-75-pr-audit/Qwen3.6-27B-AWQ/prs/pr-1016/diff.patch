+        if [[ "$backend" != "apple" ]] && declare -p SERVICE_GPU_BACKENDS &>/dev/null; then
             local gpu_backends="${SERVICE_GPU_BACKENDS[$sid]:-}"
             if [[ -n "$gpu_backends" && ! " $gpu_backends " =~ " $backend " ]]; then
