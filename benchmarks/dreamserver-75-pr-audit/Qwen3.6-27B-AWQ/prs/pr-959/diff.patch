-
-GREEN='\033[0;32m'
-RED='\033[0;31m'
-NC='\033[0m'
-PASS=0
-FAIL=0
-
-pass() { echo -e "  ${GREEN}PASS${NC} $1"; PASS=$((PASS + 1)); }
-fail() { echo -e "  ${RED}FAIL${NC} $1"; FAIL=$((FAIL + 1)); }
-
-echo ""
-echo "=== Windows OpenCode config tests ==="
-echo ""
-
-[[ -f "$DEVTOOLS_PS1" ]] && pass "07-devtools.ps1 exists" || fail "07-devtools.ps1 missing"
