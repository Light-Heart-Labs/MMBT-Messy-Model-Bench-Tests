+    assert_output "ios-ashell"
+}
+
+@test "detect_platform: supports explicit override" {
+    export DREAM_PLATFORM_OVERRIDE="android-termux"
+
+    run detect_platform
+    assert_success
+    assert_output "android-termux"
+}
