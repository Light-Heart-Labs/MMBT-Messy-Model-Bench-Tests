+            hook.write_text("#!/bin/bash\nexit 0\n", encoding="utf-8")
+            hook.chmod(0o755)
+            (ext_dir / "manifest.yaml").write_text(
+                "service:\n"
+                "  port: 1234\n"
+                "  hooks:\n"
+                "    post_install: setup.sh\n",
+                encoding="utf-8",
